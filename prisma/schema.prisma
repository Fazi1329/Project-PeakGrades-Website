generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  MODERATOR
  ADMIN
}

model User {
  id        String @id @default(cuid())
  email     String @unique
  password  String
  role      Role  @default(STUDENT)
  name      String?
}
